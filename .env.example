RESEND_API_KEY=re_your_key_here

# Frontend (Vite) — anon key only, safe for browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Resend is used for all outbound email:
# - Lead forms: Vercel api/submit.ts (set RESEND_API_KEY on Vercel)
# - Portal activation: Supabase Edge Functions (set RESEND_API_KEY as Supabase secret)
#   supabase secrets set RESEND_API_KEY=re_your_key_here

# Employee portal uses Supabase email/password auth (not Google OAuth).
# Enable "Confirm email" in Supabase Dashboard → Authentication → Providers → Email.
# Redirect URLs: http://localhost:8080/onboarding/activate and http://localhost:8080/portal
# Edge Function secret: PNCL_SITE_URL=http://localhost:8080 (production: your live URL)
# Setup guide: docs/portal-email-auth-setup.md
# Restrict sign-in to @thepncl.com accounts (enforced in app + Google hd param).

# Supabase Edge Function secrets (set via scripts/setup-onboarding-secrets.sh — never commit keys)
# GOOGLE_WORKSPACE_ADMIN_EMAIL=dm@thepncl.com
# GOOGLE_SERVICE_ACCOUNT_EMAIL=onboarding-service-account@employee-onboarding-499721.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_CLIENT_ID=101589819016618734344
# GOOGLE_WORKSPACE_CUSTOMER_ID=my_customer
# PNCL_EMAIL_DOMAIN=thepncl.com
# PNCL_GOOGLE_RECOVERY_EMAIL=   (fallback only — normal onboarding uses contract personal email)
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=   (from service account JSON — set via CLI only)
# CREDENTIAL_ENCRYPTION_KEY=         (generate: openssl rand -base64 32)
